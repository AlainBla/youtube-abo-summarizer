# ── OpenRouter (default) ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI GPT OSS 120B - Context 131k			# OR Price: in 0,04 - out 0,19 - Q4: 64G, FB16: 66G
OPENROUTER_MODEL=openai/gpt-oss-120b

# Gemma3 27b  - Context 128k				# OR price: in 0,08 - out 0,16 - Q4: 17G, FP16: 54G
#OPENROUTER_MODEL=google/gemma-3-27b-it

# Phi4 - Context 16k					# OR price: in 0,06 - out 0,14 - Q4:  9G, FP16: 30G
#OPENROUTER_MODEL=microsoft/phi-4

# Qwen3 30b A3B Instruct 2507 - Context 256K 		# OR price: in 0,09 - out 0,30 - Q4: 19G, FP16: 62G
#OPENROUTER_MODEL=qwen/qwen3-30b-a3b-instruct-2507

# ── Local Ollama (alternative) ───────────────────────────────────────────────
# LLM_* variables take precedence over OPENROUTER_* when both are set.
# Precedence: LLM_MODEL > OPENROUTER_MODEL, LLM_BASE_URL > OpenRouter URL,
#             LLM_API_KEY > OPENROUTER_API_KEY.
# LLM_API_KEY is not required for Ollama (a dummy key is used automatically).
#LLM_BASE_URL=http://localhost:11434/v1
#LLM_MODEL=gemma3:27b


# Optional: language for LLM-generated summaries (default: German)
# Use any natural language name understood by the model, e.g. English, French, Spanish.
#SUMMARY_LANG=German

# Optional: preferred transcript languages, comma-separated, in priority order (default: de,en)
# Falls back to any available language if none of the listed ones are found.
#TRANSCRIPT_LANGS=de,en

# Optional: Webshare residential proxy for transcript fetching
# Format: http://USERNAME:PASSWORD@p.webshare.io:80
WEBSHARE_PROXY_URL=

# SMTP settings for send_mail.py
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=user@example.com   # optional, defaults to SMTP_USER
