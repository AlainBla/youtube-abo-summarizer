<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YouTube Summary — {{ generated_date }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: #0f0f0f;
      color: #e0e0e0;
      line-height: 1.6;
      padding: 2rem 1rem;
    }

    .page-header {
      max-width: 900px;
      margin: 0 auto 2.5rem;
      border-bottom: 2px solid #ff0000;
      padding-bottom: 1rem;
    }
    .page-header h1 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #fff;
    }
    .page-header .meta {
      color: #888;
      font-size: 0.9rem;
      margin-top: 0.25rem;
    }

    .channel-section {
      max-width: 900px;
      margin: 0 auto 3rem;
    }
    .channel-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1.25rem;
    }
    .channel-header h2 {
      font-size: 1.3rem;
      font-weight: 600;
      color: #fff;
    }
    .channel-badge {
      background: #ff0000;
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.15rem 0.5rem;
      border-radius: 3px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .video-card {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      display: flex;
      gap: 1.25rem;
      padding: 1.1rem;
      margin-bottom: 1rem;
      transition: border-color 0.15s;
    }
    .video-card:hover { border-color: #444; }

    .video-thumb {
      flex-shrink: 0;
      width: 200px;
    }
    .video-thumb img {
      width: 100%;
      border-radius: 5px;
      display: block;
    }
    .video-thumb .no-thumb {
      width: 100%;
      aspect-ratio: 16/9;
      background: #2a2a2a;
      border-radius: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #555;
      font-size: 0.75rem;
    }

    .video-body { flex: 1; min-width: 0; }

    .video-title {
      font-size: 1rem;
      font-weight: 600;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 0.25rem;
    }
    .video-title:hover { color: #ff4444; }

    .video-meta {
      font-size: 0.8rem;
      color: #777;
      margin-bottom: 0.9rem;
    }

    .video-summary a.ts-link {
      color: #ff6b6b;
      font-size: 0.78rem;
      font-family: monospace;
      background: #2a1515;
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
      text-decoration: none;
      margin-right: 0.35rem;
    }
    .video-summary a.ts-link:hover {
      background: #3d1e1e;
      color: #ff9999;
    }

    .video-summary h3 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0.75rem 0 0.3rem;
    }
    .video-summary h3:first-child { margin-top: 0; }
    .video-summary p { font-size: 0.92rem; color: #ccc; margin-bottom: 0.5rem; }
    .video-summary ul { padding-left: 1.2rem; margin-bottom: 0.5rem; }
    .video-summary li { font-size: 0.92rem; color: #ccc; margin-bottom: 0.2rem; }

    .no-transcript {
      font-size: 0.88rem;
      font-style: italic;
      padding: 0.4rem 0.7rem;
      border-radius: 4px;
      border-left: 3px solid;
    }
    .no-transcript.unavailable {
      color: #666;
      border-color: #333;
    }
    .no-transcript.ip-blocked {
      color: #c0824a;
      background: #1f1508;
      border-color: #7a4a1a;
    }
    .no-transcript.rate-limited {
      color: #b0a040;
      background: #181508;
      border-color: #6a5f10;
    }

    .no-videos {
      color: #555;
      font-style: italic;
      font-size: 0.9rem;
      padding: 0.5rem 0;
    }

    .page-footer {
      max-width: 900px;
      margin: 2rem auto 0;
      border-top: 1px solid #2a2a2a;
      padding-top: 1rem;
      color: #555;
      font-size: 0.8rem;
      text-align: center;
    }

    @media (max-width: 600px) {
      .video-card { flex-direction: column; }
      .video-thumb { width: 100%; }
    }
  </style>
</head>
<body>

<header class="page-header">
  <h1>YouTube Summary</h1>
  <p class="meta">Generated {{ generated_date }} &mdash; {{ total_videos }} video{{ 's' if total_videos != 1 else '' }} across {{ channels|length }} channel{{ 's' if channels|length != 1 else '' }}</p>
</header>

{% for channel in channels %}
<section class="channel-section">
  <div class="channel-header">
    <h2>{{ channel.title }}</h2>
    <span class="channel-badge">{{ channel.videos|length }} new</span>
  </div>

  {% if channel.videos %}
    {% for video in channel.videos %}
    <article class="video-card">
      <div class="video-thumb">
        {% if video.thumbnail_url %}
          <img src="{{ video.thumbnail_url }}" alt="{{ video.title }}">
        {% else %}
          <div class="no-thumb">No thumbnail</div>
        {% endif %}
      </div>
      <div class="video-body">
        <a class="video-title" href="https://www.youtube.com/watch?v={{ video.video_id }}" target="_blank">{{ video.title }}</a>
        <div class="video-meta">{{ video.published_at }}</div>
        <div class="video-summary">
          {% if video.summary %}
            {{ video.summary }}
          {% elif video.transcript_error == "ip_blocked" %}
            <p class="no-transcript ip-blocked">&#x26A0; Kein Transkript &mdash; YouTube blockiert Transkript-Anfragen von dieser IP-Adresse (Rechenzentrum erkannt).</p>
          {% elif video.transcript_error == "rate_limited" %}
            <p class="no-transcript rate-limited">&#x26A0; Kein Transkript &mdash; YouTube hat die Anfrage abgelehnt (zu viele Anfragen in kurzer Zeit).</p>
          {% else %}
            <p class="no-transcript unavailable">Kein Transkript für dieses Video verfügbar.</p>
          {% endif %}
        </div>
      </div>
    </article>
    {% endfor %}
  {% else %}
    <p class="no-videos">No new videos in the selected time range.</p>
  {% endif %}
</section>
{% endfor %}

<footer class="page-footer">
  youtube-abo-summarizer
</footer>

</body>
</html>
