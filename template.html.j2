<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ t.page_title }} — {{ generated_date }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: #0f0f0f;
      color: #e0e0e0;
      line-height: 1.6;
      padding: 2rem 1rem;
    }

    .page-header {
      max-width: 900px;
      margin: 0 auto 2rem;
      border-bottom: 2px solid #ff0000;
      padding-bottom: 1rem;
    }
    .page-header h1 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #fff;
    }
    .page-header .meta {
      color: #888;
      font-size: 0.9rem;
      margin-top: 0.25rem;
    }

    /* ── Table of contents ── */
    .toc {
      max-width: 900px;
      margin: 0 auto 2.5rem;
      background: #141414;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1rem 1.25rem;
    }
    .toc-title {
      font-size: 0.72rem;
      font-weight: 700;
      color: #555;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.75rem;
    }
    .toc-channel {
      margin-bottom: 0.55rem;
    }
    .toc-channel-link {
      font-size: 0.87rem;
      font-weight: 600;
      color: #999;
      text-decoration: none;
    }
    .toc-channel-link:hover { color: #fff; }
    .toc-videos {
      list-style: none;
      padding-left: 1rem;
      margin-top: 0.15rem;
    }
    .toc-videos li { padding: 0.05rem 0; }
    .toc-videos a {
      font-size: 0.82rem;
      color: #555;
      text-decoration: none;
    }
    .toc-videos a:hover { color: #bbb; }

    /* ── Channel sections ── */
    .channel-section {
      max-width: 900px;
      margin: 0 auto 3rem;
    }
    .channel-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1.25rem;
    }
    .channel-header h2 {
      font-size: 1.3rem;
      font-weight: 600;
      color: #fff;
    }
    .channel-badge {
      background: #ff0000;
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.15rem 0.5rem;
      border-radius: 3px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ── Video cards ── */
    .video-card {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      display: flex;
      gap: 1.25rem;
      padding: 1.1rem;
      margin-bottom: 1rem;
      transition: border-color 0.15s;
    }
    .video-card:hover { border-color: #444; }
    .video-card.is-read { opacity: 0.6; }
    .video-card.is-read .video-title { color: #888; }
    .video-card.is-bookmarked { border-color: #7a5a10; box-shadow: 0 0 0 1px #7a5a10; }

    .video-thumb .video-actions button {
      background: #2a2a2a;
      border: 1px solid #3a3a3a;
      border-radius: 4px;
      color: #888;
      font-size: 0.75rem;
      padding: 0.2rem 0.5rem;
      cursor: pointer;
      transition: all 0.15s;
    }
    .video-thumb .video-actions button:hover {
      background: #333;
      border-color: #555;
      color: #bbb;
    }
    .video-thumb .video-actions button.is-active {
      background: #2d4a2d;
      border-color: #4a7a4a;
      color: #a0dfa0;
    }
    .video-thumb .video-actions button.bookmark-btn.is-active {
      background: #4a3a10;
      border-color: #7a5a10;
      color: #e0c060;
    }

    .video-thumb {
      flex-shrink: 0;
      width: 200px;
      position: sticky;
      top: 1rem;
      align-self: flex-start;
    }
    .video-thumb-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
    }
    .video-thumb img {
      width: 100%;
      border-radius: 5px;
      display: block;
    }
    .video-thumb .no-thumb {
      width: 100%;
      aspect-ratio: 16/9;
      background: #2a2a2a;
      border-radius: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #555;
      font-size: 0.75rem;
    }
    .video-thumb .video-actions {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
    }

    .video-body { flex: 1; min-width: 0; }

    .video-title {
      font-size: 1rem;
      font-weight: 600;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 0.25rem;
    }
    .video-title:hover { color: #ff4444; }

    .video-meta {
      font-size: 0.8rem;
      color: #777;
      margin-bottom: 0.5rem;
    }

    .model-badge {
      display: inline-block;
      font-size: 0.7rem;
      font-family: monospace;
      color: #6a9fb5;
      background: #0d1f2d;
      border: 1px solid #1a3a52;
      border-radius: 3px;
      padding: 0.05rem 0.4rem;
      margin-left: 0.4rem;
      vertical-align: middle;
    }

    .skip-link {
      display: inline-block;
      font-size: 0.75rem;
      color: #444;
      text-decoration: none;
      border: 1px solid #2a2a2a;
      border-radius: 3px;
      padding: 0.1rem 0.5rem;
      margin-bottom: 0.75rem;
    }
    .skip-link:hover { color: #999; border-color: #555; }

    .video-summary a.ts-link {
      color: #ff6b6b;
      font-size: 0.78rem;
      font-family: monospace;
      background: #2a1515;
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
      text-decoration: none;
      margin-right: 0.35rem;
    }
    .video-summary a.ts-link:hover {
      background: #3d1e1e;
      color: #ff9999;
    }

    .video-summary h3 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0.75rem 0 0.3rem;
    }
    .video-summary h3:first-child { margin-top: 0; }
    .video-summary p { font-size: 0.92rem; color: #ccc; margin-bottom: 0.5rem; }
    .video-summary ul { padding-left: 1.2rem; margin-bottom: 0.5rem; }
    .video-summary li { font-size: 0.92rem; color: #ccc; margin-bottom: 0.2rem; }

    .no-transcript {
      font-size: 0.88rem;
      font-style: italic;
      padding: 0.4rem 0.7rem;
      border-radius: 4px;
      border-left: 3px solid;
    }
    .no-transcript.unavailable {
      color: #666;
      border-color: #333;
    }
    .no-transcript.ip-blocked {
      color: #c0824a;
      background: #1f1508;
      border-color: #7a4a1a;
    }
    .no-transcript.rate-limited {
      color: #b0a040;
      background: #181508;
      border-color: #6a5f10;
    }
    .no-transcript.country-blocked {
      color: #7a9fc0;
      background: #080e18;
      border-color: #1a3a5a;
    }

    .no-videos {
      color: #555;
      font-style: italic;
      font-size: 0.9rem;
      padding: 0.5rem 0;
    }

    .page-footer {
      max-width: 900px;
      margin: 2rem auto 0;
      border-top: 1px solid #2a2a2a;
      padding-top: 1rem;
      color: #555;
      font-size: 0.8rem;
      text-align: center;
    }

    @media (max-width: 600px) {
      .video-card { flex-direction: column; }
      .video-thumb { width: 100%; }
    }
  </style>
</head>
<body>

<header class="page-header">
  <h1>{{ t.page_title }}</h1>
  <p class="meta">{{ meta_line }}</p>
</header>

{% if channels %}
<nav class="toc">
  <p class="toc-title">{{ t.contents }}</p>
  {% for channel in channels %}
  <div class="toc-channel">
    <a class="toc-channel-link" href="#channel-{{ channel.channel_id }}">{{ channel.title }}</a>
    {% if channel.videos %}
    <ul class="toc-videos">
      {% for video in channel.videos %}
      <li><a href="#video-{{ video.video_id }}">{{ video.title }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
  {% endfor %}
</nav>
{% endif %}

{% for channel in channels %}
{% set channel_loop = loop %}
<section class="channel-section" id="channel-{{ channel.channel_id }}">
  <div class="channel-header">
    <h2>{{ channel.title }}</h2>
    <span class="channel-badge">{{ channel.videos|length }} {{ t.new_badge }}</span>
  </div>

  {% if channel.videos %}
    {% for video in channel.videos %}
    {% if not loop.last %}
      {% set next_anchor = "#video-" ~ channel.videos[loop.index0 + 1].video_id %}
    {% elif not channel_loop.last %}
      {% set next_anchor = "#channel-" ~ channels[channel_loop.index0 + 1].channel_id %}
    {% else %}
      {% set next_anchor = "" %}
    {% endif %}
    <article class="video-card" id="video-{{ video.video_id }}">
      <div class="video-thumb">
        <div class="video-thumb-inner">
          {% if video.thumbnail_url %}
            <img src="{{ video.thumbnail_url }}" alt="{{ video.title }}">
          {% else %}
            <div class="no-thumb">{{ t.no_thumb }}</div>
          {% endif %}
          <div class="video-actions">
            <button class="read-btn" data-video-id="{{ video.video_id }}" onclick="toggleRead('{{ video.video_id }}')">{{ t.read_btn }}</button>
            <button class="bookmark-btn" data-video-id="{{ video.video_id }}" onclick="toggleBookmark('{{ video.video_id }}')">{{ t.bookmark_btn }}</button>
          </div>
        </div>
      </div>
      <div class="video-body">
        <a class="video-title" href="https://www.youtube.com/watch?v={{ video.video_id }}" target="_blank">{{ video.title }}</a>
        <div class="video-meta">{{ video.published_at }}{% if video.duration %} &middot; {{ video.duration }}{% endif %}{% if video.summary_model %}<span class="model-badge">{{ video.summary_model }}</span>{% endif %}</div>
        {% if next_anchor %}<a class="skip-link" href="{{ next_anchor }}">{{ t.skip }}</a>{% endif %}
        <div class="video-summary">
          {% if video.summary %}
            {{ video.summary }}
          {% elif video.transcript_error == "ip_blocked" %}
            <p class="no-transcript ip-blocked">{{ t.transcript_ip_blocked }}</p>
          {% elif video.transcript_error == "rate_limited" %}
            <p class="no-transcript rate-limited">{{ t.transcript_rate_limited }}</p>
          {% elif video.transcript_error == "country_blocked" %}
            <p class="no-transcript country-blocked">{{ t.transcript_country_blocked }}</p>
          {% else %}
            <p class="no-transcript unavailable">{{ t.transcript_unavailable }}</p>
          {% endif %}
        </div>
      </div>
    </article>
    {% endfor %}
  {% else %}
    <p class="no-videos">{{ t.no_videos }}</p>
  {% endif %}
</section>
{% endfor %}

<footer class="page-footer">
  youtube-abo-summarizer
</footer>

<script>
(function() {
  const COOKIE_READ = 'yt_read';
  const COOKIE_BOOKMARK = 'yt_bookmark';
  const COOKIE_DAYS = 365;

  function setCookie(name, value) {
    const d = new Date();
    d.setTime(d.getTime() + (COOKIE_DAYS * 24 * 60 * 60 * 1000));
    document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + d.toUTCString() + ';path=/';
  }

  function getCookie(name) {
    const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? decodeURIComponent(match[2]) : '';
  }

  function getSet(name) {
    // Read/bookmark sets live in localStorage (MB-scale limit) rather than a
    // cookie (4096 bytes — silently stops persisting after a few hundred IDs).
    // On first run for a given browser, migrate whatever the old cookie still
    // holds, then retire the cookie so it stops accumulating.
    try {
      const raw = localStorage.getItem(name);
      if (raw !== null) return new Set(JSON.parse(raw).filter(Boolean));
    } catch (e) { /* localStorage unavailable — fall through to migration/empty */ }
    const legacy = getCookie(name);
    const migrated = legacy ? new Set(legacy.split(',').filter(Boolean)) : new Set();
    saveSet(name, migrated);
    document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
    return migrated;
  }

  function saveSet(name, set) {
    try {
      localStorage.setItem(name, JSON.stringify(Array.from(set)));
    } catch (e) { /* storage full/unavailable — state won't persist this session */ }
  }

  window.toggleRead = function(videoId) {
    const set = getSet(COOKIE_READ);
    const card = document.getElementById('video-' + videoId);
    const btn = card.querySelector('.video-thumb .read-btn');
    if (set.has(videoId)) {
      set.delete(videoId);
      card.classList.remove('is-read');
      btn.classList.remove('is-active');
    } else {
      set.add(videoId);
      card.classList.add('is-read');
      btn.classList.add('is-active');
    }
    saveSet(COOKIE_READ, set);
  };

  window.toggleBookmark = function(videoId) {
    const set = getSet(COOKIE_BOOKMARK);
    const card = document.getElementById('video-' + videoId);
    const btn = card.querySelector('.video-thumb .bookmark-btn');
    if (set.has(videoId)) {
      set.delete(videoId);
      card.classList.remove('is-bookmarked');
      btn.classList.remove('is-active');
    } else {
      set.add(videoId);
      card.classList.add('is-bookmarked');
      btn.classList.add('is-active');
    }
    saveSet(COOKIE_BOOKMARK, set);
  };

  // Initialize state on page load
  document.addEventListener('DOMContentLoaded', function() {
    const readSet = getSet(COOKIE_READ);
    const bookmarkSet = getSet(COOKIE_BOOKMARK);
    document.querySelectorAll('.video-card').forEach(function(card) {
      const videoId = card.id.replace('video-', '');
      if (readSet.has(videoId)) {
        card.classList.add('is-read');
        card.querySelector('.video-thumb .read-btn').classList.add('is-active');
      }
      if (bookmarkSet.has(videoId)) {
        card.classList.add('is-bookmarked');
        card.querySelector('.video-thumb .bookmark-btn').classList.add('is-active');
      }
    });
  });
})();
</script>

</body>
</html>
