<!DOCTYPE html>
<html lang="{{ default_lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YouTube Export — {{ generated_date }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: #0f0f0f;
      color: #e0e0e0;
      line-height: 1.6;
      padding: 2rem 1rem;
    }

    .page-header {
      max-width: 900px;
      margin: 0 auto 1.5rem;
      border-bottom: 2px solid #ff0000;
      padding-bottom: 1rem;
    }
    .header-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .page-header h1 { font-size: 1.8rem; font-weight: 700; color: #fff; }
    .page-header .meta { color: #888; font-size: 0.9rem; margin-top: 0.25rem; }

    /* ── Controls bar ── */
    .controls-bar {
      max-width: 900px;
      margin: 0 auto 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .controls-bar input[type="search"] {
      flex: 1;
      min-width: 200px;
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #e0e0e0;
      font-size: 0.95rem;
      padding: 0.45rem 0.75rem;
      outline: none;
    }
    .controls-bar input[type="search"]:focus { border-color: #555; }
    .controls-bar input[type="search"]::placeholder { color: #555; }
    .controls-bar select,
    .lang-select {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #e0e0e0;
      font-size: 0.9rem;
      padding: 0.45rem 0.75rem;
      outline: none;
      cursor: pointer;
    }
    .controls-bar select:focus,
    .lang-select:focus { border-color: #555; }
    .lang-select { align-self: center; }
    /* ── Control groups (label + select/input pairs) ── */
    .control-group {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }
    .ctrl-label {
      font-size: 0.8rem;
      color: #666;
      white-space: nowrap;
    }
    .controls-bar input[type="date"] {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #e0e0e0;
      font-size: 0.9rem;
      padding: 0.45rem 0.5rem;
      outline: none;
      cursor: pointer;
      color-scheme: dark;
    }
    .controls-bar input[type="date"]:focus { border-color: #555; }
    .controls-bar input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.7); }
    .results-count { color: #666; font-size: 0.85rem; white-space: nowrap; }

    /* ── Video cards ── */
    .video-card {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      display: flex;
      gap: 1.25rem;
      padding: 1.1rem;
      margin-bottom: 1rem;
      transition: border-color 0.15s;
    }
    .video-card:hover { border-color: #444; }
    .video-card.is-read { opacity: 0.6; }
    .video-card.is-read .video-title { color: #888; }
    .video-card.is-bookmarked { border-color: #7a5a10; box-shadow: 0 0 0 1px #7a5a10; }

    .video-actions {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 0.4rem;
    }
    .video-actions button {
      background: #2a2a2a;
      border: 1px solid #3a3a3a;
      border-radius: 4px;
      color: #888;
      font-size: 0.75rem;
      padding: 0.2rem 0.5rem;
      cursor: pointer;
      transition: all 0.15s;
    }
    .video-actions button:hover {
      background: #333;
      border-color: #555;
      color: #bbb;
    }
    .video-actions button.is-active {
      background: #2d4a2d;
      border-color: #4a7a4a;
      color: #a0dfa0;
    }
    .video-actions button.bookmark-btn.is-active {
      background: #4a3a10;
      border-color: #7a5a10;
      color: #e0c060;
    }

    .video-thumb { flex-shrink: 0; width: 200px; }
    .video-thumb img { width: 100%; border-radius: 5px; display: block; }
    .video-embed { margin-top: 6px; width: 100%; aspect-ratio: 16/9; border: none; border-radius: 5px; display: block; }
    .video-thumb .no-thumb {
      width: 100%;
      aspect-ratio: 16/9;
      background: #2a2a2a;
      border-radius: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #555;
      font-size: 0.75rem;
    }

    .video-body { flex: 1; min-width: 0; }

    .video-title {
      font-size: 1rem;
      font-weight: 600;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 0.25rem;
    }
    .video-title:hover { color: #ff4444; }

    .video-meta { font-size: 0.8rem; color: #777; margin-bottom: 0.5rem; }
    .channel-link { cursor: pointer; }
    .channel-link:hover { color: #aaa; text-decoration: underline; }

    .model-badge {
      display: inline-block;
      font-size: 0.7rem;
      font-family: monospace;
      color: #6a9fb5;
      background: #0d1f2d;
      border: 1px solid #1a3a52;
      border-radius: 3px;
      padding: 0.05rem 0.4rem;
      margin-left: 0.4rem;
      vertical-align: middle;
    }

    .video-summary a.ts-link {
      color: #ff6b6b;
      font-size: 0.78rem;
      font-family: monospace;
      background: #2a1515;
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
      text-decoration: none;
      margin-right: 0.35rem;
    }
    .video-summary a.ts-link:hover { background: #3d1e1e; color: #ff9999; }

    .summary-toggle {
      background: none;
      border: none;
      color: #555;
      font-size: 0.8rem;
      cursor: pointer;
      padding: 0.25rem 0;
      margin-top: 0.25rem;
      display: block;
    }
    .summary-toggle:hover { color: #aaa; }

    .video-summary h3 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0.75rem 0 0.3rem;
    }
    .video-summary h3:first-child { margin-top: 0; }
    .video-summary p { font-size: 0.92rem; color: #ccc; margin-bottom: 0.5rem; }
    .video-summary ul { padding-left: 1.2rem; margin-bottom: 0.5rem; }
    .video-summary li { font-size: 0.92rem; color: #ccc; margin-bottom: 0.2rem; }

    .no-transcript {
      font-size: 0.88rem;
      font-style: italic;
      padding: 0.4rem 0.7rem;
      border-radius: 4px;
      border-left: 3px solid;
    }
    .no-transcript.unavailable { color: #666; border-color: #333; }
    .no-transcript.ip-blocked { color: #c0824a; background: #1f1508; border-color: #7a4a1a; }
    .no-transcript.rate-limited { color: #b0a040; background: #181508; border-color: #6a5f10; }
    .no-transcript.country-blocked { color: #7a9fc0; background: #080e18; border-color: #1a3a5a; }

    .no-videos { color: #555; font-style: italic; font-size: 0.9rem; padding: 1rem 0; }

    /* ── Tag chips ── */
    .tag-chip {
      display: inline-block;
      font-size: 0.72rem;
      background: #1e2a1e;
      color: #7abf7a;
      border: 1px solid #2d4a2d;
      border-radius: 3px;
      padding: 0.05rem 0.45rem;
      margin: 0 0.25rem 0.25rem 0;
      cursor: pointer;
      user-select: none;
    }
    .tag-chip:hover { background: #253525; border-color: #3d6a3d; }
    .tag-chip.active { background: #2d4a2d; color: #a0dfa0; border-color: #4a7a4a; }
    .video-tags { margin-bottom: 0.4rem; }

    /* ── Pagination ── */
    .pagination {
      max-width: 900px;
      margin: 1.5rem auto 0;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .pagination button {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #ccc;
      font-size: 0.9rem;
      padding: 0.4rem 0.75rem;
      cursor: pointer;
      min-width: 2.2rem;
    }
    .pagination button:hover:not(:disabled) { border-color: #555; color: #fff; }
    .pagination button:disabled { color: #444; cursor: default; }
    .pagination button.active { background: #2a2a2a; border-color: #666; color: #fff; font-weight: 600; }
    .pagination .page-ellipsis { color: #555; padding: 0 0.2rem; font-size: 0.9rem; line-height: 2rem; }
    .pagination .page-jump { display: flex; align-items: center; gap: 0.4rem; margin-left: 0.6rem; }
    .pagination .page-jump input {
      width: 3.5rem;
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #ccc;
      font-size: 0.85rem;
      padding: 0.4rem 0.4rem;
      text-align: center;
    }
    .pagination .page-jump input:focus { outline: none; border-color: #555; color: #fff; }

    .video-card.focused {
      border-color: #ff4444;
      box-shadow: 0 0 0 1px #ff4444;
      scroll-margin-top: 1rem;
    }

    .page-footer {
      max-width: 900px;
      margin: 2rem auto 0;
      border-top: 1px solid #2a2a2a;
      padding-top: 1rem;
      color: #555;
      font-size: 0.8rem;
      text-align: center;
    }

    @media (max-width: 600px) {
      .video-card { flex-direction: column; }
      .video-thumb { width: 100%; }
    }
    {% if sync_url %}
    /* ── Sync bar ── */
    .sync-bar {
      max-width: 900px;
      margin: 0 auto 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
      font-size: 0.9rem;
    }
    .sync-bar input[type="email"],
    .sync-bar input[type="text"] {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #e0e0e0;
      font-size: 0.9rem;
      padding: 0.35rem 0.6rem;
      outline: none;
      min-width: 200px;
    }
    .sync-bar input[type="email"]:focus,
    .sync-bar input[type="text"]:focus { border-color: #555; }
    .sync-bar input[type="email"]::placeholder,
    .sync-bar input[type="text"]::placeholder { color: #555; }
    .sync-bar button {
      background: #2a2a2a;
      border: 1px solid #3a3a3a;
      border-radius: 6px;
      color: #ccc;
      font-size: 0.85rem;
      padding: 0.35rem 0.75rem;
      cursor: pointer;
    }
    .sync-bar button:hover { background: #333; }
    .sync-user-email { color: #aaa; font-size: 0.85rem; }
    .sync-status { color: #555; font-size: 0.8rem; margin-left: auto; }
    {% endif %}
  </style>
</head>
<body>

<header class="page-header">
  <div class="header-row">
    <div>
      <h1 id="page-title">YouTube Export</h1>
      <p class="meta" id="page-meta">{{ generated_date }} &mdash; {{ total_videos }} Video{{ 's' if total_videos != 1 else '' }}</p>
    </div>
    <select id="lang-select" class="lang-select" title="Language / Sprache">
      <option value="de">&#x1F1E9;&#x1F1EA; Deutsch</option>
      <option value="en">&#x1F1EC;&#x1F1E7; English</option>
    </select>
  </div>
</header>

{% if sync_url %}
<div class="sync-bar" id="sync-bar">
  <div id="sync-login">
    <input type="email" id="sync-email" placeholder="E-Mail für Sync" autocomplete="email">
    <button id="sync-send-btn" onclick="syncRequestLink()">Link senden</button>
  </div>
  <div id="sync-user" style="display:none">
    <span class="sync-user-email" id="sync-user-email"></span>
    <button id="sync-logout-btn" onclick="doLogout()">Abmelden</button>
  </div>
  <div id="sync-ingest" style="display:none">
    <input type="text" id="ingest-input" placeholder="YouTube URL oder Video-ID" autocomplete="off">
    <button id="ingest-btn" onclick="doIngest()">Hinzufügen</button>
  </div>
  <span class="sync-status" id="sync-status"></span>
</div>
{% endif %}

<div class="controls-bar">
  <input type="search" id="search" placeholder="Suchen&hellip;" autocomplete="off">
  <div class="control-group">
    <label class="ctrl-label" for="date-filter" id="label-date">Ab</label>
    <input type="date" id="date-filter">
  </div>
  <div class="control-group">
    <label class="ctrl-label" for="channel-filter" id="label-channel">Kanal</label>
    <select id="channel-filter">
      <option value="">Alle</option>
    </select>
  </div>
  <div class="control-group">
    <label class="ctrl-label" for="tag-filter" id="label-tag">Tag</label>
    <select id="tag-filter">
      <option value="">Alle</option>
    </select>
  </div>
  <div class="control-group">
    <label class="ctrl-label" for="read-filter" id="label-read">Gelesen</label>
    <select id="read-filter">
      <option value="">Alle</option>
      <option value="unread">Nur ungelesen</option>
      <option value="read">Nur gelesen</option>
    </select>
  </div>
  <div class="control-group">
    <label class="ctrl-label" for="bookmark-filter" id="label-bookmark">Merken</label>
    <select id="bookmark-filter">
      <option value="">Alle</option>
      <option value="bookmarked">Nur gemerkt</option>
    </select>
  </div>
  <div class="control-group">
    <label class="ctrl-label" for="sort" id="label-sort">Sortierung</label>
    <select id="sort">
      <option value="date-desc">Neueste zuerst</option>
      <option value="date-asc">&Auml;lteste zuerst</option>
      <option value="channel">Kanal A&ndash;Z</option>
      <option value="title">Titel A&ndash;Z</option>
    </select>
  </div>
  <span class="results-count" id="results-count"></span>
  <span class="results-count" id="key-hint" style="color:#444">j/k &mdash; vor/zur&uuml;ck</span>
</div>

<div id="grid"></div>

<div class="pagination" id="pagination"></div>

<footer class="page-footer">
  youtube-abo-summarizer
</footer>

<script>
const VIDEOS = {{ videos_json }};
const PAGE_SIZE = 20;
const TOTAL_VIDEOS = {{ total_videos }};
const GENERATED_DATE = '{{ generated_date }}';
const EMBEDDED_DEFAULT = '{{ default_lang }}';
{% if sync_url %}
const SYNC_URL = "{{ sync_url }}";
{% endif %}

// ── i18n ──────────────────────────────────────────────────────────────────────
const I18N = {
