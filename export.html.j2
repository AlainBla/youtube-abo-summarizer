<!DOCTYPE html>
<html lang="{{ default_lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YouTube Export — {{ generated_date }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: #0f0f0f;
      color: #e0e0e0;
      line-height: 1.6;
      padding: 2rem 1rem;
    }

    .page-header {
      max-width: 900px;
      margin: 0 auto 1.5rem;
      border-bottom: 2px solid #ff0000;
      padding-bottom: 1rem;
    }
    .header-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .page-header h1 { font-size: 1.8rem; font-weight: 700; color: #fff; }
    .page-header .meta { color: #888; font-size: 0.9rem; margin-top: 0.25rem; }

    /* ── Controls bar ── */
    .controls-bar {
      max-width: 900px;
      margin: 0 auto 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .controls-bar input[type="search"] {
      flex: 1;
      min-width: 200px;
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #e0e0e0;
      font-size: 0.95rem;
      padding: 0.45rem 0.75rem;
      outline: none;
    }
    .controls-bar input[type="search"]:focus { border-color: #555; }
    .controls-bar input[type="search"]::placeholder { color: #555; }
    .controls-bar select,
    .lang-select {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #e0e0e0;
      font-size: 0.9rem;
      padding: 0.45rem 0.75rem;
      outline: none;
      cursor: pointer;
    }
    .controls-bar select:focus,
    .lang-select:focus { border-color: #555; }
    .lang-select { align-self: center; }
    .results-count { color: #666; font-size: 0.85rem; white-space: nowrap; }

    /* ── Video cards ── */
    .video-card {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      display: flex;
      gap: 1.25rem;
      padding: 1.1rem;
      margin-bottom: 1rem;
      transition: border-color 0.15s;
    }
    .video-card:hover { border-color: #444; }
    .video-card.is-read { opacity: 0.6; }
    .video-card.is-read .video-title { color: #888; }
    .video-card.is-bookmarked { border-color: #7a5a10; box-shadow: 0 0 0 1px #7a5a10; }

    .video-actions {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 0.4rem;
    }
    .video-actions button {
      background: #2a2a2a;
      border: 1px solid #3a3a3a;
      border-radius: 4px;
      color: #888;
      font-size: 0.75rem;
      padding: 0.2rem 0.5rem;
      cursor: pointer;
      transition: all 0.15s;
    }
    .video-actions button:hover {
      background: #333;
      border-color: #555;
      color: #bbb;
    }
    .video-actions button.is-active {
      background: #2d4a2d;
      border-color: #4a7a4a;
      color: #a0dfa0;
    }
    .video-actions button.bookmark-btn.is-active {
      background: #4a3a10;
      border-color: #7a5a10;
      color: #e0c060;
    }

    .video-thumb { flex-shrink: 0; width: 200px; }
    .video-thumb img { width: 100%; border-radius: 5px; display: block; }
    .video-thumb .no-thumb {
      width: 100%;
      aspect-ratio: 16/9;
      background: #2a2a2a;
      border-radius: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #555;
      font-size: 0.75rem;
    }

    .video-body { flex: 1; min-width: 0; }

    .video-title {
      font-size: 1rem;
      font-weight: 600;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 0.25rem;
    }
    .video-title:hover { color: #ff4444; }

    .video-meta { font-size: 0.8rem; color: #777; margin-bottom: 0.5rem; }

    .model-badge {
      display: inline-block;
      font-size: 0.7rem;
      font-family: monospace;
      color: #6a9fb5;
      background: #0d1f2d;
      border: 1px solid #1a3a52;
      border-radius: 3px;
      padding: 0.05rem 0.4rem;
      margin-left: 0.4rem;
      vertical-align: middle;
    }

    .video-summary a.ts-link {
      color: #ff6b6b;
      font-size: 0.78rem;
      font-family: monospace;
      background: #2a1515;
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
      text-decoration: none;
      margin-right: 0.35rem;
    }
    .video-summary a.ts-link:hover { background: #3d1e1e; color: #ff9999; }

    .summary-toggle {
      background: none;
      border: none;
      color: #555;
      font-size: 0.8rem;
      cursor: pointer;
      padding: 0.25rem 0;
      margin-top: 0.25rem;
      display: block;
    }
    .summary-toggle:hover { color: #aaa; }

    .video-summary h3 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0.75rem 0 0.3rem;
    }
    .video-summary h3:first-child { margin-top: 0; }
    .video-summary p { font-size: 0.92rem; color: #ccc; margin-bottom: 0.5rem; }
    .video-summary ul { padding-left: 1.2rem; margin-bottom: 0.5rem; }
    .video-summary li { font-size: 0.92rem; color: #ccc; margin-bottom: 0.2rem; }

    .no-transcript {
      font-size: 0.88rem;
      font-style: italic;
      padding: 0.4rem 0.7rem;
      border-radius: 4px;
      border-left: 3px solid;
    }
    .no-transcript.unavailable { color: #666; border-color: #333; }
    .no-transcript.ip-blocked { color: #c0824a; background: #1f1508; border-color: #7a4a1a; }
    .no-transcript.rate-limited { color: #b0a040; background: #181508; border-color: #6a5f10; }
    .no-transcript.country-blocked { color: #7a9fc0; background: #080e18; border-color: #1a3a5a; }

    .no-videos { color: #555; font-style: italic; font-size: 0.9rem; padding: 1rem 0; }

    /* ── Tag chips ── */
    .tag-chip {
      display: inline-block;
      font-size: 0.72rem;
      background: #1e2a1e;
      color: #7abf7a;
      border: 1px solid #2d4a2d;
      border-radius: 3px;
      padding: 0.05rem 0.45rem;
      margin: 0 0.25rem 0.25rem 0;
      cursor: pointer;
      user-select: none;
    }
    .tag-chip:hover { background: #253525; border-color: #3d6a3d; }
    .tag-chip.active { background: #2d4a2d; color: #a0dfa0; border-color: #4a7a4a; }
    .video-tags { margin-bottom: 0.4rem; }

    /* ── Pagination ── */
    .pagination {
      max-width: 900px;
      margin: 1.5rem auto 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }
    .pagination button {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      color: #ccc;
      font-size: 0.9rem;
      padding: 0.4rem 1rem;
      cursor: pointer;
    }
    .pagination button:hover:not(:disabled) { border-color: #555; color: #fff; }
    .pagination button:disabled { color: #444; cursor: default; }
    .pagination .page-info { color: #777; font-size: 0.9rem; }

    .video-card.focused {
      border-color: #ff4444;
      box-shadow: 0 0 0 1px #ff4444;
      scroll-margin-top: 1rem;
    }

    .page-footer {
      max-width: 900px;
      margin: 2rem auto 0;
      border-top: 1px solid #2a2a2a;
      padding-top: 1rem;
      color: #555;
      font-size: 0.8rem;
      text-align: center;
    }

    @media (max-width: 600px) {
      .video-card { flex-direction: column; }
      .video-thumb { width: 100%; }
    }
  </style>
</head>
<body>

<header class="page-header">
  <div class="header-row">
    <div>
      <h1 id="page-title">YouTube Export</h1>
      <p class="meta" id="page-meta">{{ generated_date }} &mdash; {{ total_videos }} Video{{ 's' if total_videos != 1 else '' }}</p>
    </div>
    <select id="lang-select" class="lang-select" title="Language / Sprache">
      <option value="de">Deutsch</option>
      <option value="en">English</option>
    </select>
  </div>
</header>

<div class="controls-bar">
  <input type="search" id="search" placeholder="Suchen&hellip;" autocomplete="off">
  <select id="channel-filter">
    <option value="">Alle Kan&auml;le</option>
  </select>
  <select id="tag-filter">
    <option value="">Alle Tags</option>
  </select>
  <select id="read-filter">
    <option value="">Alle Videos</option>
    <option value="unread">Nur ungelesen</option>
    <option value="read">Nur gelesen</option>
  </select>
  <select id="bookmark-filter">
    <option value="">Alle Videos</option>
    <option value="bookmarked">Nur gemerkt</option>
  </select>
  <select id="sort">
    <option value="date-desc">Neueste zuerst</option>
    <option value="date-asc">&Auml;lteste zuerst</option>
    <option value="channel">Kanal A&ndash;Z</option>
    <option value="title">Titel A&ndash;Z</option>
  </select>
  <span class="results-count" id="results-count"></span>
  <span class="results-count" id="key-hint" style="color:#444">j/k &mdash; vor/zur&uuml;ck</span>
</div>

<div id="grid"></div>

<div class="pagination" id="pagination"></div>

<footer class="page-footer">
  youtube-abo-summarizer
</footer>

<script>
const VIDEOS = {{ videos_json }};
const PAGE_SIZE = 20;
const TOTAL_VIDEOS = {{ total_videos }};
const GENERATED_DATE = '{{ generated_date }}';
const EMBEDDED_DEFAULT = '{{ default_lang }}';

// ── i18n ──────────────────────────────────────────────────────────────────────
const I18N = {
  de: {
    pageTitle: 'YouTube Export',
    generated: function(date, n) {
      return 'Generiert ' + date + ' \u2014 ' + n + ' Video' + (n !== 1 ? 's' : '');
    },
    searchPlaceholder: 'Titel oder Zusammenfassung durchsuchen\u2026',
    allChannels: 'Alle Kan\u00e4le',
    allTags: 'Alle Tags',
    allVideos: 'Alle Videos',
    unreadOnly: 'Nur ungelesen',
    readOnly: 'Nur gelesen',
    bookmarkedOnly: 'Nur gemerkt',
    sortDateDesc: 'Neueste zuerst',
    sortDateAsc: '\u00c4lteste zuerst',
    sortChannel: 'Kanal A\u2013Z',
    sortTitle: 'Titel A\u2013Z',
    keyHint: 'j/k \u2014 vor/zur\u00fcck',
    noThumb: 'Kein Thumbnail',
    readBtn: '\u2713 Gelesen',
    bookmarkBtn: '\u2605 Merken',
    showMore: '\u25bc mehr',
    showLess: '\u25b2 weniger',
    transcriptIpBlocked: '\u26a0 Kein Transkript \u2014 YouTube blockiert Transkript-Anfragen von dieser IP-Adresse (Rechenzentrum erkannt).',
    transcriptRateLimited: '\u26a0 Kein Transkript \u2014 YouTube hat die Anfrage abgelehnt (zu viele Anfragen in kurzer Zeit).',
    transcriptCountryBlocked: '\ud83c\udf10 Kein Transkript \u2014 Video ist nur in bestimmten Regionen verf\u00fcgbar (Geoblocking).',
    transcriptUnavailable: 'Kein Transkript f\u00fcr dieses Video verf\u00fcgbar.',
    noVideos: 'Keine Videos gefunden.',
    results: function(n) { return n + ' Video' + (n !== 1 ? 's' : ''); },
    prevPage: '\u2190 Zur\u00fcck',
    pageInfo: function(cur, total) { return 'Seite ' + cur + ' von ' + total; },
    nextPage: 'Weiter \u2192'
  },
  en: {
    pageTitle: 'YouTube Export',
    generated: function(date, n) {
      return 'Generated ' + date + ' \u2014 ' + n + ' video' + (n !== 1 ? 's' : '');
    },
    searchPlaceholder: 'Search title or summary\u2026',
    allChannels: 'All channels',
    allTags: 'All tags',
    allVideos: 'All videos',
    unreadOnly: 'Unread only',
    readOnly: 'Read only',
    bookmarkedOnly: 'Bookmarked only',
    sortDateDesc: 'Newest first',
    sortDateAsc: 'Oldest first',
    sortChannel: 'Channel A\u2013Z',
    sortTitle: 'Title A\u2013Z',
    keyHint: 'j/k \u2014 prev/next',
    noThumb: 'No thumbnail',
    readBtn: '\u2713 Read',
    bookmarkBtn: '\u2605 Save',
    showMore: '\u25bc more',
    showLess: '\u25b2 less',
    transcriptIpBlocked: '\u26a0 No transcript \u2014 YouTube is blocking transcript requests from this IP address (data center detected).',
    transcriptRateLimited: '\u26a0 No transcript \u2014 YouTube rejected the request (too many requests in a short time).',
    transcriptCountryBlocked: '\ud83c\udf10 No transcript \u2014 Video is only available in certain regions (geo-blocking).',
    transcriptUnavailable: 'No transcript available for this video.',
    noVideos: 'No videos found.',
    results: function(n) { return n + ' video' + (n !== 1 ? 's' : ''); },
    prevPage: '\u2190 Back',
    pageInfo: function(cur, total) { return 'Page ' + cur + ' of ' + total; },
    nextPage: 'Next \u2192'
  }
};

var currentLang = EMBEDDED_DEFAULT;

let filtered = [];
let currentPage = 1;
let debounceTimer = null;
let focusedIndex = -1;

// ── Cookie helpers ─────────────────────────────────────────────────────────────
const COOKIE_READ = 'yt_read';
const COOKIE_BOOKMARK = 'yt_bookmark';
const COOKIE_LANG = 'yt_lang';
const COOKIE_DAYS = 365;

function setCookie(name, value) {
  const d = new Date();
  d.setTime(d.getTime() + (COOKIE_DAYS * 24 * 60 * 60 * 1000));
  document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + d.toUTCString() + ';path=/';
}

function getCookie(name) {
  const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
  return match ? decodeURIComponent(match[2]) : '';
}

function getSet(name) {
  const val = getCookie(name);
  return val ? new Set(val.split(',').filter(Boolean)) : new Set();
}

function saveSet(name, set) {
  setCookie(name, Array.from(set).join(','));
}

let readSet = getSet(COOKIE_READ);
let bookmarkSet = getSet(COOKIE_BOOKMARK);

window.toggleRead = function(videoId) {
  if (readSet.has(videoId)) {
    readSet.delete(videoId);
  } else {
    readSet.add(videoId);
  }
  saveSet(COOKIE_READ, readSet);
  applyFiltersAndSort();
};

window.toggleBookmark = function(videoId) {
  if (bookmarkSet.has(videoId)) {
    bookmarkSet.delete(videoId);
  } else {
    bookmarkSet.add(videoId);
  }
  saveSet(COOKIE_BOOKMARK, bookmarkSet);
  applyFiltersAndSort();
};

// ── Language detection ─────────────────────────────────────────────────────────
function detectLang() {
  var cookieLang = getCookie(COOKIE_LANG);
  if (cookieLang && I18N[cookieLang]) return cookieLang;

  var browserLangs = navigator.languages ? Array.from(navigator.languages) : [navigator.language || ''];
  for (var i = 0; i < browserLangs.length; i++) {
    var prefix = browserLangs[i].split('-')[0].toLowerCase();
    if (I18N[prefix]) return prefix;
  }

  if (I18N[EMBEDDED_DEFAULT]) return EMBEDDED_DEFAULT;
  return 'de';
}

// ── Apply language ─────────────────────────────────────────────────────────────
function applyLang(lang) {
  currentLang = lang;
  setCookie(COOKIE_LANG, lang);
  var s = I18N[lang];

  document.documentElement.lang = lang;
  document.title = s.pageTitle + ' \u2014 ' + GENERATED_DATE;
  document.getElementById('page-title').textContent = s.pageTitle;
  document.getElementById('page-meta').textContent = s.generated(GENERATED_DATE, TOTAL_VIDEOS);
  document.getElementById('search').placeholder = s.searchPlaceholder;
  document.getElementById('key-hint').textContent = s.keyHint;
  document.getElementById('lang-select').value = lang;

  // channel-filter first option
  document.querySelector('#channel-filter option[value=""]').textContent = s.allChannels;
  // tag-filter first option
  document.querySelector('#tag-filter option[value=""]').textContent = s.allTags;

  // read-filter
  var rfOpts = document.getElementById('read-filter').options;
  rfOpts[0].textContent = s.allVideos;
  rfOpts[1].textContent = s.unreadOnly;
  rfOpts[2].textContent = s.readOnly;

  // bookmark-filter
  var bfOpts = document.getElementById('bookmark-filter').options;
  bfOpts[0].textContent = s.allVideos;
  bfOpts[1].textContent = s.bookmarkedOnly;

  // sort
  var sortOpts = document.getElementById('sort').options;
  sortOpts[0].textContent = s.sortDateDesc;
  sortOpts[1].textContent = s.sortDateAsc;
  sortOpts[2].textContent = s.sortChannel;
  sortOpts[3].textContent = s.sortTitle;

  applyFiltersAndSort();
}

// ── Populate channel filter dropdown ──────────────────────────────────────────
(function() {
  var seen = {};
  var channels = [];
  VIDEOS.forEach(function(v) {
    if (!seen[v.channel_id]) {
      seen[v.channel_id] = true;
      channels.push({id: v.channel_id, title: v.channel_title});
    }
  });
  channels.sort(function(a, b) {
    return a.title.localeCompare(b.title, undefined, {sensitivity: 'base'});
  });
  var sel = document.getElementById('channel-filter');
  channels.forEach(function(c) {
    var opt = document.createElement('option');
    opt.value = c.id;
    opt.textContent = c.title;
    sel.appendChild(opt);
  });
})();

// ── Populate tag filter dropdown ───────────────────────────────────────────────
(function() {
  var seen = {};
  var tags = [];
  VIDEOS.forEach(function(v) {
    (v.tags || []).forEach(function(t) {
      if (!seen[t]) { seen[t] = true; tags.push(t); }
    });
  });
  tags.sort(function(a, b) { return a.localeCompare(b, undefined, {sensitivity: 'base'}); });
  var sel = document.getElementById('tag-filter');
  tags.forEach(function(t) {
    var opt = document.createElement('option');
    opt.value = t; opt.textContent = t;
    sel.appendChild(opt);
  });
})();

function setTagFilter(tag) {
  var sel = document.getElementById('tag-filter');
  sel.value = (sel.value === tag) ? '' : tag;
  applyFiltersAndSort();
}

function escHtml(s) {
  return String(s == null ? '' : s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function stripHtml(html) {
  return html ? html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ') : '';
}

function buildCard(v) {
  var s = I18N[currentLang];

  const thumb = v.thumbnail_url
    ? '<img src="' + escHtml(v.thumbnail_url) + '" alt="' + escHtml(v.title) + '">'
    : '<div class="no-thumb">' + s.noThumb + '</div>';

  let metaExtras = '';
  if (v.duration) metaExtras += ' &middot; ' + escHtml(v.duration);
  if (v.summary_model) metaExtras += '<span class="model-badge">' + escHtml(v.summary_model) + '</span>';

  let summaryHtml;
  if (v.summary) {
    const cut = v.summary.indexOf('</p>');
    const rest = cut !== -1 ? v.summary.slice(cut + 4).trim() : '';
    const preview = cut !== -1 ? v.summary.slice(0, cut + 4) : v.summary;
    if (rest) {
      summaryHtml = preview
        + '<button class="summary-toggle" onclick="toggleSummary(this)">' + s.showMore + '</button>'
        + '<div class="summary-details" hidden>' + rest + '</div>';
    } else {
      summaryHtml = preview;
    }
  } else if (v.transcript_error === 'ip_blocked') {
    summaryHtml = '<p class="no-transcript ip-blocked">' + s.transcriptIpBlocked + '</p>';
  } else if (v.transcript_error === 'rate_limited') {
    summaryHtml = '<p class="no-transcript rate-limited">' + s.transcriptRateLimited + '</p>';
  } else if (v.transcript_error === 'country_blocked') {
    summaryHtml = '<p class="no-transcript country-blocked">' + s.transcriptCountryBlocked + '</p>';
  } else {
    summaryHtml = '<p class="no-transcript unavailable">' + s.transcriptUnavailable + '</p>';
  }

  var tagsHtml = '';
  if (v.tags && v.tags.length) {
    var activeTag = document.getElementById('tag-filter').value;
    tagsHtml = '<div class="video-tags">'
      + v.tags.map(function(t) {
          var cls = 'tag-chip' + (activeTag === t ? ' active' : '');
          return '<span class="' + cls + '" onclick="setTagFilter(\'' + escHtml(t) + '\')">' + escHtml(t) + '</span>';
        }).join('')
      + '</div>';
  }

  const isRead = readSet.has(v.video_id);
  const isBookmarked = bookmarkSet.has(v.video_id);
  const cardClass = 'video-card' + (isRead ? ' is-read' : '') + (isBookmarked ? ' is-bookmarked' : '');
  const readBtnClass = 'read-btn' + (isRead ? ' is-active' : '');
  const bookmarkBtnClass = 'bookmark-btn' + (isBookmarked ? ' is-active' : '');

  return '<article class="' + cardClass + '">'
    + '<div class="video-thumb">' + thumb + '</div>'
    + '<div class="video-body">'
    + '<div class="video-actions">'
    + '<button class="' + readBtnClass + '" onclick="toggleRead(\'' + escHtml(v.video_id) + '\')">' + s.readBtn + '</button>'
    + '<button class="' + bookmarkBtnClass + '" onclick="toggleBookmark(\'' + escHtml(v.video_id) + '\')">' + s.bookmarkBtn + '</button>'
    + '</div>'
    + '<a class="video-title" href="https://www.youtube.com/watch?v=' + escHtml(v.video_id) + '" target="_blank" rel="noopener">' + escHtml(v.title) + '</a>'
    + '<div class="video-meta">' + escHtml(v.channel_title) + ' &middot; ' + escHtml(v.published_at_display) + metaExtras + '</div>'
    + tagsHtml
    + '<div class="video-summary">' + summaryHtml + '</div>'
    + '</div>'
    + '</article>';
}

function applyFiltersAndSort() {
  const q = document.getElementById('search').value.trim().toLowerCase();
  const sort = document.getElementById('sort').value;
  const channelId = document.getElementById('channel-filter').value;
  const tagFilter = document.getElementById('tag-filter').value;
  const readFilter = document.getElementById('read-filter').value;
  const bookmarkFilter = document.getElementById('bookmark-filter').value;

  filtered = VIDEOS.filter(function(v) {
    if (channelId && v.channel_id !== channelId) return false;
    if (tagFilter && !(v.tags || []).includes(tagFilter)) return false;
    if (readFilter === 'read' && !readSet.has(v.video_id)) return false;
    if (readFilter === 'unread' && readSet.has(v.video_id)) return false;
    if (bookmarkFilter === 'bookmarked' && !bookmarkSet.has(v.video_id)) return false;
    if (q) {
      var text = v.title.toLowerCase() + ' ' + stripHtml(v.summary || '').toLowerCase();
      if (text.indexOf(q) === -1) return false;
    }
    return true;
  });

  focusedIndex = -1;

  filtered.sort(function(a, b) {
    switch (sort) {
      case 'date-asc':
        return a.published_at.localeCompare(b.published_at);
      case 'channel': {
        var c = a.channel_title.localeCompare(b.channel_title, undefined, {sensitivity: 'base'});
        return c !== 0 ? c : b.published_at.localeCompare(a.published_at);
      }
      case 'title':
        return a.title.localeCompare(b.title, undefined, {sensitivity: 'base'});
      default: // date-desc
        return b.published_at.localeCompare(a.published_at);
    }
  });

  renderPage(1);
}

function renderPage(page) {
  var s = I18N[currentLang];
  var total = filtered.length;
  var pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
  currentPage = Math.min(Math.max(1, page), pages);

  var start = (currentPage - 1) * PAGE_SIZE;
  var slice = filtered.slice(start, start + PAGE_SIZE);

  document.getElementById('grid').innerHTML = slice.length
    ? slice.map(buildCard).join('')
    : '<p class="no-videos">' + s.noVideos + '</p>';

  // Restore focused highlight after re-render
  if (focusedIndex >= 0) {
    var localIdx = focusedIndex - (currentPage - 1) * PAGE_SIZE;
    var cards = document.getElementById('grid').querySelectorAll('.video-card');
    if (cards[localIdx]) cards[localIdx].classList.add('focused');
  }

  document.getElementById('results-count').textContent = s.results(total);

  var pag = document.getElementById('pagination');
  if (pages <= 1) { pag.innerHTML = ''; return; }

  var prevDisabled = currentPage <= 1 ? ' disabled' : '';
  var nextDisabled = currentPage >= pages ? ' disabled' : '';
  pag.innerHTML =
    '<button onclick="renderPage(' + (currentPage - 1) + ')"' + prevDisabled + '>' + s.prevPage + '</button>'
    + '<span class="page-info">' + s.pageInfo(currentPage, pages) + '</span>'
    + '<button onclick="renderPage(' + (currentPage + 1) + ')"' + nextDisabled + '>' + s.nextPage + '</button>';
}

function toggleSummary(btn) {
  var details = btn.nextElementSibling;
  var open = details.hidden === false;
  details.hidden = open;
  btn.textContent = open ? I18N[currentLang].showMore : I18N[currentLang].showLess;
}

function focusCard(idx) {
  if (filtered.length === 0) return;
  idx = Math.max(0, Math.min(filtered.length - 1, idx));
  focusedIndex = idx;

  var targetPage = Math.floor(idx / PAGE_SIZE) + 1;
  if (targetPage !== currentPage) {
    renderPage(targetPage);
  } else {
    var cards = document.getElementById('grid').querySelectorAll('.video-card');
    cards.forEach(function(c) { c.classList.remove('focused'); });
    var localIdx = idx - (currentPage - 1) * PAGE_SIZE;
    if (cards[localIdx]) cards[localIdx].classList.add('focused');
  }

  var localIdx = idx - (currentPage - 1) * PAGE_SIZE;
  var cards = document.getElementById('grid').querySelectorAll('.video-card');
  if (cards[localIdx]) cards[localIdx].scrollIntoView({behavior: 'smooth', block: 'nearest'});
}

document.addEventListener('keydown', function(e) {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.tagName === 'TEXTAREA') return;
  if (e.metaKey || e.ctrlKey || e.altKey) return;
  if (e.key === 'j' || e.key === 'ArrowDown') {
    e.preventDefault();
    focusCard(focusedIndex < 0 ? 0 : focusedIndex + 1);
  } else if (e.key === 'k' || e.key === 'ArrowUp') {
    e.preventDefault();
    focusCard(focusedIndex < 0 ? 0 : focusedIndex - 1);
  }
});

document.getElementById('search').addEventListener('input', function() {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(applyFiltersAndSort, 200);
});

document.getElementById('channel-filter').addEventListener('change', applyFiltersAndSort);
document.getElementById('tag-filter').addEventListener('change', applyFiltersAndSort);
document.getElementById('read-filter').addEventListener('change', applyFiltersAndSort);
document.getElementById('bookmark-filter').addEventListener('change', applyFiltersAndSort);
document.getElementById('sort').addEventListener('change', applyFiltersAndSort);
document.getElementById('lang-select').addEventListener('change', function() {
  applyLang(this.value);
});

applyLang(detectLang());
</script>

</body>
</html>
