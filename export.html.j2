    },
    searchPlaceholder: 'Search title or summary\u2026',
    allChannels: 'All',
    allTags: 'All',
    allVideos: 'All',
    labelFrom: 'From',
    labelChannel: 'Channel',
    labelTag: 'Tag',
    labelRead: 'Read',
    labelBookmark: 'Bookmark',
    labelSort: 'Sort',
    unreadOnly: 'Unread only',
    readOnly: 'Read only',
